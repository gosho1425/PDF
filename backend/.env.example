# ─────────────────────────────────────────────────────────────────────────────
# PaperLens v2 — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env in the backend/ directory and fill in your values.
# NEVER commit .env — it contains your API key.
#
#   Windows:  copy backend\.env.example backend\.env
#   Mac/Linux: cp backend/.env.example backend/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Configuration ─────────────────────────────────────────────────────────
# Provider: "anthropic" (default) | "openai"
LLM_PROVIDER=anthropic
# Model name — must match the provider's model IDs:
#   Anthropic: claude-sonnet-4-5  claude-3-5-haiku-20241022
#   OpenAI:    gpt-4o             gpt-4o-mini
LLM_MODEL=claude-sonnet-4-5
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=120

# ── API Keys (keep these secret!) ─────────────────────────────────────────────
# Set only the key for the provider you chose above.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# ── Storage ───────────────────────────────────────────────────────────────────
# Where to store the SQLite DB and output files.
# Default: backend/data/  (relative to where you run uvicorn)
# Windows example: DATA_DIR=C:\PaperLens\data
DATA_DIR=data

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
