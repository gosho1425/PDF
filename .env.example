# ─────────────────────────────────────────────────────────────────────────────
# PaperLens Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=PaperLens
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_FORMAT=json                  # json | console
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=paperlens
POSTGRES_USER=paperlens
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD   # ← Required

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=                             # Optional

# ── LLM API (Claude / Anthropic) ─────────────────────────────────────────────
# SECURITY: This key is used SERVER-SIDE ONLY.
# Never put this in frontend code or expose it to the browser.
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX   # ← Required
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_TEMPERATURE=0.1
LLM_MAX_CHUNK_CHARS=60000
LLM_TIMEOUT_SECONDS=120

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local            # local | s3
DATA_DIR=/app/data               # Must be writable

# ── Folder-based PDF Ingestion ────────────────────────────────────────────────
# HOST_PAPER_DIR  – the folder on your HOST machine that contains the PDFs.
#   Windows example : HOST_PAPER_DIR=C:\Users\YourName\Documents\papers
#   macOS / Linux   : HOST_PAPER_DIR=/home/yourname/papers
#
# INGEST_DIR – the path INSIDE the container where the host folder is mounted.
#   Leave this as /ingest unless you have a specific reason to change it.
#
# These two variables work together in docker-compose.yml:
#   volumes:
#     - ${HOST_PAPER_DIR}:/ingest:ro
HOST_PAPER_DIR=C:\Users\YourName\Documents\papers   # ← Change to your folder
INGEST_DIR=/ingest

# S3 (only needed when STORAGE_BACKEND=s3):
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAXXX
# AWS_SECRET_ACCESS_KEY=XXXXXXXX

# ── PDF Processing ─────────────────────────────────────────────────────────────
# MAX_UPLOAD_SIZE_MB – also used as a guard when copying files from INGEST_DIR
MAX_UPLOAD_SIZE_MB=100
OCR_ENABLED=true
OCR_MIN_TEXT_THRESHOLD=200
# TESSERACT_CMD=/usr/bin/tesseract  # Override if not in PATH

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Ports (Docker Compose) ───────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000
FLOWER_PORT=5555

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# This is SAFE to expose – it is just the backend URL, not a secret.
NEXT_PUBLIC_API_URL=http://localhost:8000
