# ─────────────────────────────────────────────────────────────────────────────
# PaperLens Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=PaperLens
ENVIRONMENT=development
DEBUG=false
LOG_FORMAT=json
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=paperlens
POSTGRES_USER=paperlens
# REQUIRED — change from the placeholder before running docker compose up
# Use letters, digits, and underscores only; avoid @ # / % ? : in passwords.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── LLM API (Claude / Anthropic) ─────────────────────────────────────────────
# SECURITY: This key is used SERVER-SIDE ONLY.
# Never put this in frontend code or expose it to the browser.
# REQUIRED — get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_TEMPERATURE=0.1
LLM_MAX_CHUNK_CHARS=60000
LLM_TIMEOUT_SECONDS=120

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
DATA_DIR=/app/data

# ── Folder-based PDF Ingestion ────────────────────────────────────────────────
#
# HOST_PAPER_DIR — the folder on YOUR host machine that contains the PDF files.
#
# ⚠️  WINDOWS RULES — read carefully to avoid "Not mounted" in the UI:
#   1. Change the path below to your actual folder path.
#   2. NO inline comments after the path value (# causes the comment text to
#      become part of the path and the mount will fail).
#   3. NO trailing spaces after the path.
#   4. Both backslashes and forward slashes work: C:\papers or C:/papers
#
# Windows example (change YourName and the folder name):
HOST_PAPER_DIR=C:\Users\YourName\Documents\papers
#
# macOS / Linux example (uncomment and edit):
# HOST_PAPER_DIR=/home/yourname/papers
#
# INGEST_DIR — the path INSIDE the container where HOST_PAPER_DIR is mounted.
# Leave this as /ingest unless you have a specific reason to change it.
INGEST_DIR=/ingest
#
# COMPOSE_CONVERT_WINDOWS_PATHS — required on Windows so Docker Compose
# correctly converts C:\... drive-letter paths in volume mounts.
# Set to 1 on Windows, leave at 0 (or remove) on macOS/Linux.
COMPOSE_CONVERT_WINDOWS_PATHS=1

# S3 (only needed when STORAGE_BACKEND=s3):
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAXXX
# AWS_SECRET_ACCESS_KEY=XXXXXXXX

# ── PDF Processing ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
OCR_ENABLED=true
OCR_MIN_TEXT_THRESHOLD=200
# TESSERACT_CMD=/usr/bin/tesseract

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Ports (Docker Compose) ───────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000
FLOWER_PORT=5555

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# This is SAFE to expose — it is just the backend URL, not a secret.
NEXT_PUBLIC_API_URL=http://localhost:8000
